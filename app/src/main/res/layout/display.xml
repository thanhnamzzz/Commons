<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:background="#33000000"
    tools:layout_height="wrap_content"
    tools:orientation="vertical"
    tools:parentTag="android.widget.LinearLayout">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/source_value_container"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="0dp"
        app:hintEnabled="false"
        app:suffixText="m"
        app:suffixTextColor="?colorOnBackground">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/source_value"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:cursorVisible="false"
            android:gravity="center_vertical|end"
            android:hint="@string/zero_hint"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:maxLines="2"
            android:minLines="1"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:text="555"
            android:textColor="?colorOnBackground"
            android:textSize="48sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_20sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_weight="1"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:labelFor="@id/source_spinner"
                app:boxStrokeColor="?colorSecondary"
                app:boxStrokeWidth="2dp"
                app:endIconTint="@color/black">

                <AutoCompleteTextView
                    android:id="@+id/source_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="@string/metre"
                    android:textColor="?colorOnBackground" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:labelFor="@id/result_spinner"
                app:boxStrokeColor="?colorSecondary"
                app:boxStrokeWidth="2dp"
                app:endIconTint="@color/black">

                <AutoCompleteTextView
                    android:id="@+id/result_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:text="@string/metre"
                    android:textColor="?colorOnBackground" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <ImageButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_circle_white"
            android:contentDescription="SwapUnit"
            android:padding="@dimen/_9sdp"
            app:srcCompat="@drawable/ic_swap_vert"
            app:tint="@color/black" />

    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/result_value_container"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="0dp"
        app:hintEnabled="false"
        app:suffixText="m"
        app:suffixTextColor="?colorOnBackground">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/result_value"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:cursorVisible="false"
            android:gravity="center_vertical|end"
            android:hint="@string/zero_hint"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:maxLines="2"
            android:minLines="1"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:text="55"
            android:textColor="?colorOnBackground"
            android:textSize="48sp" />

    </com.google.android.material.textfield.TextInputLayout>

</merge>
